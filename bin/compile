#!/usr/bin/env bash
# bin/compile <build-dir> <cache-dir> <env-dir>
# $HOME: /app

# fail fast
set -eu -o pipefail

BUILD_DIR=${1:-}
CACHE_DIR=${2:-}
ENV_DIR=${3:-}
LP_DIR=$(
  cd "$(dirname "$0")"
  cd ..
  pwd
)

# Install bun
export BUN_INSTALL=$CACHE_DIR/bun
export PATH="$BUN_INSTALL/bin:$PATH"

# Resolve BUN_VERSION. Precedence:
#   1. BUN_VERSION config var (Heroku passes config vars as files in $ENV_DIR)
#   2. .bun-version file in the repo
#   3. --stable
# The env var wins so you can flip versions per-app (e.g. to test a new bun
# on one app) without committing a code change.
if [ -n "$ENV_DIR" ] && [ -f "$ENV_DIR/BUN_VERSION" ]; then
  echo "Getting BUN_VERSION from BUN_VERSION config var"
  BUN_VERSION=$(cat "$ENV_DIR/BUN_VERSION")
elif [ -f "$BUILD_DIR"/.bun-version ]; then
  echo "Trying to get BUN_VERSION from $BUILD_DIR/.bun-version file"
  BUN_VERSION=$(cat "$BUILD_DIR"/.bun-version)
else
  BUN_VERSION="--stable"
fi
echo "------> BUN_VERSION = $BUN_VERSION"

install_bun() {
  # Wipe any cached binary so the installer lays down a clean copy.
  # `bun upgrade <version>` is not a supported command, so we always
  # (re)install via the official script when the version changes.
  rm -rf "$BUN_INSTALL"
  curl -fsSL https://bun.sh/install | bash -s "bun-v$BUN_VERSION"
}

# Check if bun is already installed
if [ -f "$BUN_INSTALL"/bin/bun ]; then
  INSTALLED_VERSION=$(bun --version)
  echo "------> Bun $INSTALLED_VERSION is already installed"

  # Compare installed version with desired version
  if [ "$INSTALLED_VERSION" != "$BUN_VERSION" ]; then
    echo "Reinstalling bun: $INSTALLED_VERSION -> $BUN_VERSION"
    install_bun
  else
    echo "Bun is already at the desired version $BUN_VERSION"
  fi
else
  echo "Bun is not installed. Installing version $BUN_VERSION"
  install_bun
fi


cat <<EOT >"$BUILD_DIR"/.bunfig.toml
[install.cache]
# the directory to use for the cache
dir = "$CACHE_DIR/bun/install/cache"
EOT

# download dependencies
cd "$BUILD_DIR"
bun install --ignore-scripts

# give environment to later buildpacks
export | grep -E -e ' (PATH)=' >"$LP_DIR/export"
